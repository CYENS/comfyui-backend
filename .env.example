# Admin seed credentials used by: uv run python -m app.seed
USER_NAME=admin
USER_PASSWORD=admin123
WORKFLOW_CREATOR_USER_NAME=workflow_creator
WORKFLOW_CREATOR_USER_PASSWORD=workflow123
JOB_CREATOR_USER_NAME=job_creator
JOB_CREATOR_USER_PASSWORD=job123
VIEWER_USER_NAME=viewer
VIEWER_USER_PASSWORD=viewer123
MODERATOR_USER_NAME=moderator
MODERATOR_USER_PASSWORD=moderator123
STORAGE_ROOT=./data/app
DATABASE_URL=sqlite:///./backend.db
COMFY_BASE_URL=http://127.0.0.1:8188
COMFY_MODELS_DIR=/app/models
