digraph ERD {\n  rankdir=LR;\n  node [shape=record, fontsize=10];\n  "asset_exports" [label="{asset_exports|id : VARCHAR(36) PK\lasset_id : VARCHAR(36)\lstatus : VARCHAR(12)\lexport_path : TEXT\lmanifest_path : TEXT\lexported_at : DATETIME\l}"];\n  "asset_validation_current" [label="{asset_validation_current|asset_id : VARCHAR(36) PK\lstatus : VARCHAR(8)\lmoderator_user_id : VARCHAR(36)\lvalidated_at : DATETIME\lnotes : TEXT\lupdated_at : DATETIME\l}"];\n  "asset_validations" [label="{asset_validations|id : VARCHAR(36) PK\lasset_id : VARCHAR(36)\lmoderator_user_id : VARCHAR(36)\lstatus : VARCHAR(8)\lnotes : TEXT\lvalidated_at : DATETIME\lcreated_at : DATETIME\l}"];\n  "assets" [label="{assets|id : VARCHAR(36) PK\ljob_id : VARCHAR(36)\lworkflow_id : VARCHAR(36)\lworkflow_version_id : VARCHAR(36)\ltype : VARCHAR(5)\lfile_path : TEXT\loriginal_filename : TEXT\lsize_bytes : BIGINT\lchecksum_sha256 : VARCHAR(64)\lmedia_type : VARCHAR(128)\lcreated_at : DATETIME\l}"];\n  "job_input_values" [label="{job_input_values|id : VARCHAR(36) PK\ljob_id : VARCHAR(36)\linput_id : VARCHAR(128)\lvalue_json : JSON\lcreated_at : DATETIME\l}"];\n  "jobs" [label="{jobs|id : VARCHAR(36) PK\lcomfy_job_id : VARCHAR(64)\luser_id : VARCHAR(36)\lworkflow_id : VARCHAR(36)\lworkflow_version_id : VARCHAR(36)\lstatus : VARCHAR(9)\lstart_time : DATETIME\lend_time : DATETIME\lerror_message : TEXT\lsubmitted_at : DATETIME\lcreated_at : DATETIME\lupdated_at : DATETIME\l}"];\n  "roles" [label="{roles|id : VARCHAR(36) PK\lname : VARCHAR(16)\lcreated_at : DATETIME\l}"];\n  "user_roles" [label="{user_roles|user_id : VARCHAR(36) PK\lrole_id : VARCHAR(36) PK\lcreated_at : DATETIME\l}"];\n  "users" [label="{users|id : VARCHAR(36) PK\lusername : VARCHAR(128)\lpassword_hash : VARCHAR(255)\lcreated_at : DATETIME\lupdated_at : DATETIME\l}"];\n  "workflow_versions" [label="{workflow_versions|id : VARCHAR(36) PK\lworkflow_id : VARCHAR(36)\lversion_number : INTEGER\lprompt_json : JSON\linputs_schema_json : JSON\lprompt_hash : VARCHAR(128)\lcreated_by_user_id : VARCHAR(36)\lchange_note : TEXT\lis_published : BOOLEAN\lcreated_at : DATETIME\l}"];\n  "workflows" [label="{workflows|id : VARCHAR(36) PK\lkey : VARCHAR(128)\lname : VARCHAR(255)\ldescription : TEXT\lcreated_by_user_id : VARCHAR(36)\lparent_workflow_id : VARCHAR(36)\lcurrent_version_id : VARCHAR(36)\lis_active : BOOLEAN\lcreated_at : DATETIME\lupdated_at : DATETIME\l}"];\n  "asset_exports" -> "assets" [label="asset_id -> id"];\n  "asset_validation_current" -> "users" [label="moderator_user_id -> id"];\n  "asset_validation_current" -> "assets" [label="asset_id -> id"];\n  "asset_validations" -> "users" [label="moderator_user_id -> id"];\n  "asset_validations" -> "assets" [label="asset_id -> id"];\n  "assets" -> "workflow_versions" [label="workflow_version_id -> id"];\n  "assets" -> "workflows" [label="workflow_id -> id"];\n  "assets" -> "jobs" [label="job_id -> id"];\n  "job_input_values" -> "jobs" [label="job_id -> id"];\n  "jobs" -> "workflow_versions" [label="workflow_version_id -> id"];\n  "jobs" -> "workflows" [label="workflow_id -> id"];\n  "jobs" -> "users" [label="user_id -> id"];\n  "user_roles" -> "roles" [label="role_id -> id"];\n  "user_roles" -> "users" [label="user_id -> id"];\n  "workflow_versions" -> "users" [label="created_by_user_id -> id"];\n  "workflow_versions" -> "workflows" [label="workflow_id -> id"];\n  "workflows" -> "workflow_versions" [label="current_version_id -> id"];\n  "workflows" -> "workflows" [label="parent_workflow_id -> id"];\n  "workflows" -> "users" [label="created_by_user_id -> id"];\n}